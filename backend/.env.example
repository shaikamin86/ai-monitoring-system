# ════════════════════════════════════════════════════════════════════════
#  Malaysia AI Social Monitor — environment variables
#  Copy to .env and fill in real values before running.
# ════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string
CORS_ORIGINS=["http://localhost:3000"]

# ── Supabase ─────────────────────────────────────────────────────────────
# Project URL and keys from: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...     # anon/public key

# ── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Redis ────────────────────────────────────────────────────────────────
# Local:  redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ════════════════════════════════════════════════════════════════════════
#  Social platform credentials
# ════════════════════════════════════════════════════════════════════════

# ── Twitter / X ──────────────────────────────────────────────────────────
# Bearer Token for app-only auth (Twitter API v2 Recent Search).
# Required tier: Basic ($100/mo) or higher.
# Get it from: https://developer.twitter.com/en/portal/dashboard
#   1. Create a project + app
#   2. Generate a Bearer Token (App-only)
TWITTER_BEARER_TOKEN=

# ── Facebook ─────────────────────────────────────────────────────────────
# Long-lived Page Access Token or System User Token.
# Required permissions: pages_read_engagement, pages_show_list
#
# How to get a long-lived token:
#   1. Go to https://developers.facebook.com/tools/explorer/
#   2. Select your app → Generate User Token with the permissions above
#   3. Exchange it for a long-lived token via:
#      GET https://graph.facebook.com/v19.0/oauth/access_token
#          ?grant_type=fb_exchange_token
#          &client_id={APP_ID}
#          &client_secret={APP_SECRET}
#          &fb_exchange_token={short_lived_token}
#   4. For a non-expiring token use a System User in Business Manager.
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_APP_ID=
# Optional extra pages to monitor (JSON array):
# FACEBOOK_EXTRA_PAGES=[{"id": "pageslug", "name": "Page Name"}]
FACEBOOK_EXTRA_PAGES=[]

# ── TikTok Research API ───────────────────────────────────────────────────
# Requires an approved Research API application.
# Apply at: https://developers.tiktok.com/products/research-api/
# After approval, create an app and grab the Client Key + Secret.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── RSS ───────────────────────────────────────────────────────────────────
# Optional extra feeds beyond the built-in 10 Malaysian outlets.
# JSON array: [{"url": "https://example.com/feed", "source": "My Outlet"}]
RSS_EXTRA_FEEDS=[]

# ════════════════════════════════════════════════════════════════════════
#  Ingestion scheduler tuning
# ════════════════════════════════════════════════════════════════════════
INGESTION_ENABLED=true
INGESTION_RSS_INTERVAL_MIN=10
INGESTION_TWITTER_INTERVAL_MIN=5
INGESTION_FACEBOOK_INTERVAL_MIN=15
INGESTION_TIKTOK_INTERVAL_MIN=30

# ════════════════════════════════════════════════════════════════════════
#  Telegram notifications
# ════════════════════════════════════════════════════════════════════════

# ── Bot setup ─────────────────────────────────────────────────────────────
#   1. Message @BotFather on Telegram → /newbot → follow prompts
#   2. Copy the API token (format: 123456789:ABC…xyz)
#   3. Add the bot to your channel/group as an Administrator
#   4. Get chat ID: message the bot, then call:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      The chat.id field is what you need (negative for groups/channels)
TELEGRAM_BOT_TOKEN=

# JSON array of chat IDs and/or @channel usernames, e.g.:
#   TELEGRAM_CHAT_IDS=["-100123456789", "@my_ops_channel"]
# These are used automatically for narrative_spike alerts — no DB setup needed.
# To receive ALL alert types, add a channel via POST /api/v1/alerts/channels.
TELEGRAM_CHAT_IDS=[]

# Minimum alert severity to forward to Telegram: low | medium | high | critical
# Applies to the env-var channel above.  DB-configured channels have their own setting.
TELEGRAM_MIN_SEVERITY=high

# ════════════════════════════════════════════════════════════════════════
#  Email notifications (SMTP)
# ════════════════════════════════════════════════════════════════════════

# ── Gmail quick setup ────────────────────────────────────────────────────
#   1. Enable 2-Step Verification on your Google account
#   2. Go to Account → Security → App Passwords
#   3. Create an App Password for "Mail" → use that 16-char password below
#   4. Use smtp.gmail.com:587 (STARTTLS) — no other config needed
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Defaults to SMTP_USERNAME if blank:
SMTP_FROM=

# JSON array of recipient addresses, e.g.:
#   EMAIL_RECIPIENTS=["ops@example.com", "analyst@example.com"]
EMAIL_RECIPIENTS=[]

# Minimum alert severity to send email: low | medium | high | critical
EMAIL_MIN_SEVERITY=medium

# ════════════════════════════════════════════════════════════════════════
#  Frontend (Next.js) — prefix with NEXT_PUBLIC_ for client-side access
# ════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
